{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-system.local/schemas/agent.schema.json",
  "title": "Agent Registry Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["agents"],
  "properties": {
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "folder",
          "stage",
          "persona_file",
          "skills_file",
          "input_dir",
          "output_dir",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["po", "ba", "designer", "developer", "tester", "pm"]
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "folder": {
            "type": "string",
            "pattern": "^agents/"
          },
          "stage": {
            "type": "string",
            "enum": [
              "01_requirements",
              "02_analysis",
              "03_design",
              "04_implementation",
              "05_testing",
              "06_delivery"
            ]
          },
          "persona_file": {
            "type": "string",
            "pattern": "^agents/.+/persona\\.md$"
          },
          "skills_file": {
            "type": "string",
            "pattern": "^agents/.+/skills\\.yml$"
          },
          "input_dir": {
            "type": "string",
            "pattern": "^stages/.+/input$"
          },
          "output_dir": {
            "type": "string",
            "pattern": "^stages/.+/output$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
